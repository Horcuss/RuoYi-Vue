<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.summonsSystem.mapper.EinkDisplayContentMapper">

    <resultMap type="com.ruoyi.summonsSystem.vo.EinkDisplayContent" id="EinkDisplayContentResult">
        <result property="id"                  column="id" />
        <result property="rfid"                column="rfid" />
        <result property="lotNo"               column="lot_no" />
        <result property="productName"         column="product_name" />
        <result property="productModel"        column="product_model" />
        <result property="customer"            column="customer" />
        <result property="currentProcessCode"  column="current_process_code" />
        <result property="currentProcessName"  column="current_process_name" />
        <result property="gpDefectInfo"        column="gp_defect_info" />
        <result property="displayData"         column="display_data" />
        <result property="updateTime"          column="update_time" />
        <result property="status"              column="status" />
    </resultMap>

    <sql id="selectVo">
        select id, rfid, lot_no, product_name, product_model, customer,
               current_process_code, current_process_name, gp_defect_info,
               display_data, update_time, status
        from ticket_eink_display_content
    </sql>

    <select id="selectByRfid" parameterType="String" resultMap="EinkDisplayContentResult">
        <include refid="selectVo"/>
        where rfid = #{rfid}
    </select>

    <select id="selectByLotNo" parameterType="String" resultMap="EinkDisplayContentResult">
        <include refid="selectVo"/>
        where lot_no = #{lotNo}
    </select>

    <insert id="insert" parameterType="com.ruoyi.summonsSystem.vo.EinkDisplayContent" useGeneratedKeys="true" keyProperty="id">
        insert into ticket_eink_display_content
        (rfid, lot_no, product_name, product_model, customer,
         current_process_code, current_process_name, gp_defect_info,
         display_data, update_time, status)
        values
        (#{rfid}, #{lotNo}, #{productName}, #{productModel}, #{customer},
         #{currentProcessCode}, #{currentProcessName}, #{gpDefectInfo},
         #{displayData}, now(), #{status})
    </insert>

    <update id="updateByRfid" parameterType="com.ruoyi.summonsSystem.vo.EinkDisplayContent">
        update ticket_eink_display_content
        <trim prefix="SET" suffixOverrides=",">
            <if test="lotNo != null">lot_no = #{lotNo},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="productModel != null">product_model = #{productModel},</if>
            <if test="customer != null">customer = #{customer},</if>
            <if test="currentProcessCode != null">current_process_code = #{currentProcessCode},</if>
            <if test="currentProcessName != null">current_process_name = #{currentProcessName},</if>
            gp_defect_info = #{gpDefectInfo},
            <if test="displayData != null">display_data = #{displayData},</if>
            update_time = now(),
            <if test="status != null">status = #{status},</if>
        </trim>
        where rfid = #{rfid}
    </update>

    <delete id="deleteByRfid" parameterType="String">
        delete from ticket_eink_display_content where rfid = #{rfid}
    </delete>

</mapper>
