<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.summonsSystem.mapper.ProcessCodeMappingMapper">

    <resultMap type="com.ruoyi.summonsSystem.vo.ProcessCodeMapping" id="ProcessCodeMappingResult">
        <result property="processCode" column="process_code" />
        <result property="processName" column="process_name" />
    </resultMap>

    <select id="selectByCode" parameterType="String" resultMap="ProcessCodeMappingResult">
        select process_code, process_name
        from ticket_process_code_mapping
        where process_code = #{processCode}
    </select>

    <select id="selectAll" resultMap="ProcessCodeMappingResult">
        select process_code, process_name
        from ticket_process_code_mapping
    </select>

</mapper>
