<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.summonsSystem.mapper.DefectDetailMapper">

    <resultMap type="com.ruoyi.summonsSystem.vo.DefectDetail" id="DefectDetailResult">
        <result property="id"          column="id" />
        <result property="lotNo"       column="lot_no" />
        <result property="processCode" column="process_code" />
        <result property="processName" column="process_name" />
        <result property="defectItem"  column="defect_item" />
        <result property="sampleCount" column="sample_count" />
        <result property="createTime"  column="create_time" />
        <result property="createBy"    column="create_by" />
    </resultMap>

    <select id="selectByLotNo" parameterType="String" resultMap="DefectDetailResult">
        select id, lot_no, process_code, process_name, defect_item, sample_count, create_time, create_by
        from ticket_defect_detail
        where lot_no = #{lotNo}
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.summonsSystem.vo.DefectDetail" useGeneratedKeys="true" keyProperty="id">
        insert into ticket_defect_detail
        (lot_no, process_code, process_name, defect_item, sample_count, create_time, create_by)
        values
        (#{lotNo}, #{processCode}, #{processName}, #{defectItem}, #{sampleCount}, now(), #{createBy})
    </insert>

</mapper>
