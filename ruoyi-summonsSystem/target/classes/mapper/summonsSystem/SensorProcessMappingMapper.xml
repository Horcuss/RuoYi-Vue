<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.summonsSystem.mapper.SensorProcessMappingMapper">

    <resultMap type="com.ruoyi.summonsSystem.vo.SensorProcessMapping" id="SensorProcessMappingResult">
        <result property="id"           column="id" />
        <result property="sensorIp"     column="sensor_ip" />
        <result property="sensorPort"   column="sensor_port" />
        <result property="processCode"  column="process_code" />
        <result property="sensorType"   column="sensor_type" />
        <result property="locationDesc" column="location_desc" />
        <result property="status"       column="status" />
        <result property="remark"       column="remark" />
    </resultMap>

    <select id="selectByIpAndPort" resultMap="SensorProcessMappingResult">
        select id, sensor_ip, sensor_port, process_code, sensor_type, location_desc, status, remark
        from ticket_sensor_process_mapping
        where sensor_ip = #{sensorIp} and sensor_port = #{sensorPort} and status = '0'
    </select>

</mapper>
